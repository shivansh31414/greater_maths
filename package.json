{
  "name": "scientific-toolkit",
  "version": "1.0.0",
  "description": "Scientific computation toolkit for Node.js with CLI and reusable API.",
  "main": "src/index.js",
  "bin": {
    "scientific-toolkit": "bin/cli.js"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "LICENSE",
    "docs"
  ],
  "scripts": {
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "jest",,
    "docs": "typedoc src/index.js --out docs/api --plugin typedoc-plugin-markdown --hideBreadcrumbs",
    "docs:build": "npm run docs && npm run docs:examples"
    "coverage": "jest --coverage"
  },
  "keywords": [
    "scientific",
    "math",
    "linear-algebra",
    "calculus",
    "prob,
    "plugins",
    "latex",
    "graphing",
    "astrophysics",
    "bioinformatics"ability",
    "units",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "pendencies": {
    "plotly.js-dist-min": "^2.26.0"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.3",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "typedoc": "^0.25.2",
    "typedoc-plugin-markdown": "^3.16.0
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.3",
    "jest": "^29.7.0",
    "prettier": "^3.5.3"
  }
}
